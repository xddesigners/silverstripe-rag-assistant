{
    "name": "xddesigners/silverstripe-rag-assistant",
    "description": "RAG-based referral assistant for SilverStripe: indexes pages via OpenAI embeddings and directs visitors to the correct page.",
    "type": "silverstripe-vendormodule",
    "keywords": ["silverstripe", "RAG", "AI", "assistant", "OpenAI", "embeddings", "chatbot"],
    "license": "BSD-3-Clause",
    "authors": [
        {
            "name": "Remy Vaartjes",
            "email": "remy@xd.nl"
        }
    ],
    "require": {
        "php": ">=8.0",
        "silverstripe/framework": "^4.0 || ^5.0",
        "silverstripe/cms": "^4.0 || ^5.0",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "extra": {
        "expose": [
            "client/dist"
        ]
    },
    "autoload": {
        "psr-4": {
            "XD\\RAGAssistant\\": "src/"
        }
    }
}
